"""
# Week 3: Deep Learning & Visual Inspection (CNNs)
This notebook demonstrates the architecture of a Convolutional Neural Network 
designed to inspect images of manufactured components for defects.



import tensorflow as tf
from tensorflow.keras import layers, models
import numpy as np

# 1. Define the CNN Architecture
def build_inspection_model(input_shape=(128, 128, 3)):
    """
    Builds a CNN model for binary classification (Defective vs. OK).
    """
    model = models.Sequential([
        # Block 1
        layers.Conv2D(32, (3, 3), activation='relu', input_shape=input_shape),
        layers.MaxPooling2D((2, 2)),
        
        # Block 2
        layers.Conv2D(64, (3, 3), activation='relu'),
        layers.MaxPooling2D((2, 2)),
        
        # Block 3
        layers.Conv2D(128, (3, 3), activation='relu'),
        layers.MaxPooling2D((2, 2)),
        
        # Classifier Head
        layers.Flatten(),
        layers.Dense(128, activation='relu'),
        layers.Dropout(0.5), # Prevent overfitting
        layers.Dense(1, activation='sigmoid') # Binary output: 0 (OK) or 1 (Defective)
    ])
    
    return model

print("🏭 Initializing Visual QA CNN...")
cnn_model = build_inspection_model()

cnn_model.compile(optimizer='adam',
                  loss='binary_crossentropy',
                  metrics=['accuracy'])

cnn_model.summary()

# 2. Generate Mock Image Tensors (Simulating a batch of 128x128 RGB images)
print("\n[INFO] Generating mock image tensors for compilation testing...")
num_samples = 100
mock_images = np.random.rand(num_samples, 128, 128, 3).astype('float32')
# Mock labels: 0 for OK, 1 for Defective
mock_labels = np.random.randint(2, size=(num_samples, 1)).astype('float32') 

# 3. Test the training loop
print("[INFO] Executing trial training epoch...")
history = cnn_model.fit(
    x=mock_images, 
    y=mock_labels, 
    batch_size=10, 
    epochs=2, 
    verbose=1,
    validation_split=0.2
)
print("\n✅ CNN Architecture validated and training loop successful.")
